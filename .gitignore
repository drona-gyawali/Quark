# Dependency directory
node_modules/

# TypeScript compiler output
# Depending on your tsconfig.json, this is often 'dist' or 'outDir'
# Adjust the path below to match your project's build output folder
/dist
/build
/coverage
*.js.map # Source maps

# Environment files
.env
.env.local
.env.*.local

# npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
pnpm-error.log*
app.ts.log*
# IDE and OS files
.vscode/        # VS Code directory (optional, remove if you want to share workspace settings)
!.vscode/tasks.json # Exception to ignore rule (example)
!.vscode/settings.json # Exception to ignore rule (example)
.idea/          # IntelliJ IDEs directory
.DS_Store       # macOS specific files
Thumbs.db       # Windows specific files

# Next.js
.next/

# SvelteKit
.svelte-kit/

settings.json
venv/

.log