{
  "name": "learnrag-4x",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc src/index.ts --outDir dist",
    "start": "NODE_ENV=production node dist/index.js",
    "cli": "npx tsx -r ./src/cli/preload.cjs src/cli/index.ts",
    "worker": "tsx src/workers/ingestion-worker.ts",
    "esbuild": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "find node_modules/voyageai/dist/esm -name '*.mjs' | while read f; do sed -Ei -e 's#from \"(\\.[^\"]*/[^\".]+)\"#from \"\\1.mjs\"#g' -e \"s#from '(\\.[^']*/[^'.]+)'#from '\\1.mjs'#g\" \"$f\"; sed -Ei -e 's#\\.\\./api\\.mjs#../api/index.mjs#g' -e 's#\\.\\./errors\\.mjs#../errors/index.mjs#g' -e 's#\\.\\./local\\.mjs#../local/index.mjs#g' \"$f\"; done"
  },
  "keywords": [
    "AI",
    "RAG",
    "unstructured",
    "parser",
    "AI-chatbot"
  ],
  "author": "Dorna Raj Gyawali <dronarajgyawali@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dotenv": "^6.1.1",
    "@types/ioredis": "^4.28.10",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/phoenix": "^1.6.7",
    "@types/yargs": "^17.0.35",
    "@types/yargs-parser": "^21.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "istanbul-lib-coverage": "^3.2.2",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "supabase": "^2.84.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/node": "^1.4.5",
    "@qdrant/js-client-rest": "^1.13.0",
    "@supabase/supabase-js": "^2.99.3",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.73.0",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.27",
    "ioredis": "^5.10.1",
    "marked": "^17.0.3",
    "mem0ai": "^1.0.39",
    "openai": "^6.25.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^4.7.1",
    "unstructured-client": "^0.31.0",
    "voyageai": "^0.2.1",
    "zod": "^4.3.6"
  }
}
